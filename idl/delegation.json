{
  "version": "0.4.1",
  "name": "delegation",
  "instructions": [
    {
      "name": "delegate",
      "accounts": [
        { "name": "handOwner", "isMut": true, "isSigner": true },
        { "name": "hand", "isMut": true, "isSigner": false },
        { "name": "delegation", "isMut": true, "isSigner": false },
        { "name": "systemProgram", "isMut": false, "isSigner": false },
        { "name": "clock", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "agent", "type": "publicKey" },
        {
          "name": "scope",
          "type": {
            "defined": "DelegationScope"
          }
        }
      ]
    },
    {
      "name": "updateScope",
      "accounts": [
        { "name": "handOwner", "isMut": false, "isSigner": true },
        { "name": "hand", "isMut": false, "isSigner": false },
        { "name": "delegation", "isMut": true, "isSigner": false }
      ],
      "args": [
        {
          "name": "newScope",
          "type": { "defined": "DelegationScope" }
        }
      ]
    },
    {
      "name": "revokeDelegation",
      "accounts": [
        { "name": "handOwner", "isMut": false, "isSigner": true },
        { "name": "hand", "isMut": true, "isSigner": false },
        { "name": "delegation", "isMut": true, "isSigner": false }
      ],
      "args": []
    },
    {
      "name": "consume",
      "accounts": [
        { "name": "delegation", "isMut": true, "isSigner": false },
        { "name": "hand", "isMut": false, "isSigner": false },
        { "name": "agent", "isMut": false, "isSigner": true },
        { "name": "clock", "isMut": false, "isSigner": false }
      ],
      "args": [
        { "name": "lamports", "type": "u64" },
        { "name": "action", "type": "u16" },
        { "name": "programId", "type": "publicKey" }
      ]
    }
  ],
  "accounts": [
    {
      "name": "Delegation",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "hand", "type": "publicKey" },
          { "name": "agent", "type": "publicKey" },
          { "name": "scope", "type": { "defined": "DelegationScope" } },
          { "name": "delegatedAt", "type": "i64" },
          { "name": "lastConsumedAt", "type": "i64" },
          { "name": "active", "type": "bool" },
          { "name": "bump", "type": "u8" }
        ]
      }
    }
  ],
  "types": [
    {
      "name": "DelegationScope",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "allowedPrograms", "type": { "vec": "publicKey" } },
          { "name": "maxLamportsPerTx", "type": "u64" },
          { "name": "maxLamportsTotal", "type": "u64" },
          { "name": "spentLamports", "type": "u64" },
          { "name": "expiresAt", "type": "i64" },
          { "name": "allowedActions", "type": "u16" }
        ]
      }
    }
  ],
  "events": [
    {
      "name": "DelegationCreated",
      "fields": [
        { "name": "hand", "type": "publicKey", "index": true },
        { "name": "agent", "type": "publicKey", "index": true },
        { "name": "delegatedAt", "type": "i64", "index": false }
      ]
    },
    {
      "name": "DelegationRevoked",
      "fields": [
        { "name": "hand", "type": "publicKey", "index": true },
        { "name": "agent", "type": "publicKey", "index": true }
      ]
    },
    {
      "name": "ScopeUpdated",
      "fields": [
        { "name": "delegation", "type": "publicKey", "index": true }
      ]
    },
    {
      "name": "DelegationConsumed",
      "fields": [
        { "name": "delegation", "type": "publicKey", "index": true },
        { "name": "lamports", "type": "u64", "index": false },
        { "name": "action", "type": "u16", "index": false }
      ]
    }
  ],
  "errors": [
    { "code": 6000, "name": "HandNotActive", "msg": "The linked Hand is not active" },
    { "code": 6001, "name": "HandNotVerified", "msg": "Hand verification is incomplete" },
    { "code": 6002, "name": "TooManyDelegations", "msg": "Maximum delegations per Hand reached" },
    { "code": 6003, "name": "DelegationNotActive", "msg": "This delegation has been revoked" },
    { "code": 6004, "name": "DelegationExpired", "msg": "This delegation has expired" },
    { "code": 6005, "name": "InsufficientBudget", "msg": "Transaction exceeds spending limit" },
    { "code": 6006, "name": "ActionNotAllowed", "msg": "This action type is not permitted" },
    { "code": 6007, "name": "ProgramNotAllowed", "msg": "Target program is not in the whitelist" },
    { "code": 6008, "name": "UnauthorizedCaller", "msg": "Caller is not the Hand owner" },
    { "code": 6009, "name": "InvalidScope", "msg": "Scope parameters are invalid" },
    { "code": 6010, "name": "MaxProgramsExceeded", "msg": "Too many programs in whitelist" }
  ],
  "metadata": {
    "address": "11111111111111111111111111111111"
  }
}
